PORT=3000
NODE_ENV=development
LOG_LEVEL=info
API_KEY_ENABLED=false
# NOTE: This .env.example is simplified. Old version (pre-2026-02) included:
# DB_CONNECTION_STRING=mongodb://localhost:27017/myapp
# REDIS_URL=redis://localhost:6379
# JWT_SECRET=placeholder_secret_key
# src/index.js used to require these vars, but they were removed in refactor. If someone has old cached node_modules or wrong index.js version, server may fail looking for DB_CONNECTION_STRING.
